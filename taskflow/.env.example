# Copie ce fichier en ".env" et remplis tes propres valeurs

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=motdepasse
DB_NAME=taskflow

# Serveur
PORT=3000

# JWT / Sessions
JWT_SECRET=change_cette_valeur_par_une_chaine_secrete_longue
# Durée de vie du token d'accès (court) ; le refresh token prend le relais
ACCESS_TOKEN_EXPIRES_IN=15m
# Durée de vie du refresh token, en jours
REFRESH_TOKEN_EXPIRES_DAYS=30
# Rétro-compat : utilisé si ACCESS_TOKEN_EXPIRES_IN est absent
JWT_EXPIRES_IN=15m

# Optionnel : taille du pool de connexions MySQL
# DB_POOL_LIMIT=10

# Rappels d'échéance automatiques (optionnel)
# Intervalle du balayage en millisecondes (défaut : 900000 = 15 min)
# DUE_REMINDER_INTERVAL_MS=900000
# Fenêtre d'anticipation en jours pour une échéance "proche" (défaut : 1)
# DUE_REMINDER_DAYS=1
