RewriteEngine On
RewriteBase /

# 1. Redirect root to public/index.html
RewriteRule ^$ public/index.html [L]

# 2. Redirect to public/ if the file exists there (CSS, JS, icons, manifest, etc.)
RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
RewriteRule ^(.*)$ public/$1 [L]

# 3. Route all other requests (like /api/...) to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
