# ==========================================================================
# coachlink.env — Secrets & configuration d'environnement (PRODUCTION).
#
# Copié en api/config/coachlink.env par setup.sh, puis chmod 600.
# NE JAMAIS versionner ce fichier avec de vraies valeurs.
# Toutes les clés sont lues par deploy/config.production.php.
# ==========================================================================

# --- Domaine / URLs -------------------------------------------------------
CL_APP_URL=https://coachlink.ci
CL_CORS_ORIGINS=https://coachlink.ci

# --- Sécurité (généré par setup.sh) --------------------------------------
CL_JWT_SECRET=

# --- Base de données MySQL -----------------------------------------------
CL_DB_DRIVER=mysql
CL_DB_HOST=127.0.0.1
CL_DB_PORT=3306
CL_DB_NAME=coachlink
CL_DB_USER=coachlink
CL_DB_PASSWORD=

# --- Uploads / cache ------------------------------------------------------
CL_UPLOADS_URL=/api/uploads
CL_CACHE_DIR=/var/cache/coachlink

# --- Paiement Mobile Money (mode 'reel' pour activer) ---------------------
CL_PAY_MODE=simulateur
CL_PAY_CALLBACK_URL=https://coachlink.ci/api/paiements/callback
CL_PAY_CALLBACK_SECRET=
# Orange
CL_PAY_ORANGE_ACTIF=false
CL_PAY_ORANGE_ID=
CL_PAY_ORANGE_SECRET=
CL_PAY_ORANGE_XAUTH=
# Wave
CL_PAY_WAVE_ACTIF=false
CL_PAY_WAVE_KEY=
# MTN
CL_PAY_MTN_ACTIF=false
CL_PAY_MTN_USER=
CL_PAY_MTN_KEY=
CL_PAY_MTN_SUBKEY=
CL_PAY_MTN_ENV=production
# Moov
CL_PAY_MOOV_ACTIF=false
CL_PAY_MOOV_BASE=
CL_PAY_MOOV_ID=
CL_PAY_MOOV_SECRET=

# --- Email (mode 'smtp' pour activer l'envoi réel) ------------------------
CL_MAIL_MODE=log
CL_MAIL_FROM=no-reply@coachlink.ci
CL_SMTP_HOST=
CL_SMTP_PORT=587
CL_SMTP_CHIFFREMENT=tls
CL_SMTP_USER=
CL_SMTP_PASSWORD=

# --- Connexion sociale (OAuth) -------------------------------------------
CL_OAUTH_REDIRECT_BASE=https://coachlink.ci/api
CL_OAUTH_FB_ACTIF=false
CL_OAUTH_FB_ID=
CL_OAUTH_FB_SECRET=
CL_OAUTH_LI_ACTIF=false
CL_OAUTH_LI_ID=
CL_OAUTH_LI_SECRET=
