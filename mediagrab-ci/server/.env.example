# --- Serveur ---
PORT=3000
NODE_ENV=development

# Origine CORS autorisée (ex: https://mediagrab.ci). '*' en développement.
CORS_ORIGIN=*

# --- yt-dlp ---
# Chemin vers un binaire yt-dlp personnalisé (optionnel).
# Laisser vide pour utiliser le binaire fourni par youtube-dl-exec.
# YTDLP_PATH=/usr/local/bin/yt-dlp

# Délai maximum d'extraction des métadonnées (ms).
EXTRACT_TIMEOUT=25000

# Délai maximum d'un téléchargement (ms).
DOWNLOAD_TIMEOUT=300000

# --- Rate limiting ---
RATE_WINDOW_MS=60000
RATE_INFO_MAX=20
RATE_DOWNLOAD_MAX=8
