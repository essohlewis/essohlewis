# ─────────────────────────────────────────────────────────────
# CONTEO — Variables d'environnement (exemple)
# Copiez ce fichier vers .env et renseignez les valeurs réelles.
# NE JAMAIS committer le fichier .env réel.
# ─────────────────────────────────────────────────────────────

# Application
APP_ENV=local              # local | production
APP_DEBUG=true             # false en production
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Abidjan

# Base de données MySQL 8
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=conteo
DB_USER=conteo
DB_PASS=change_me
DB_CHARSET=utf8mb4

# Sécurité
# Clé secrète utilisée pour signer / dériver des jetons. 64+ caractères aléatoires.
APP_KEY=change_me_to_a_long_random_string
TOKEN_TTL_DAYS=30          # durée de vie des jetons API
CSRF_TTL_MINUTES=120

# Rate limiting (requêtes par fenêtre)
RATE_AUTH_MAX=10           # tentatives auth / fenêtre
RATE_AUTH_WINDOW=300       # secondes
RATE_PAY_MAX=5
RATE_PAY_WINDOW=300

# CDN médias
CDN_BASE_URL=https://cdn.conteo.ci

# ─── CinetPay ───
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
# IPs autorisées pour le webhook (séparées par des virgules)
CINETPAY_WEBHOOK_IPS=

# ─── PayDunya ───
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test         # test | live
PAYDUNYA_WEBHOOK_IPS=

# ─── SMS / OTP ───
SMS_PROVIDER=log           # log | letexto | orange
SMS_API_KEY=
SMS_SENDER=CONTEO
