{
  "name": "conteo",
  "version": "1.0.0",
  "description": "Conteo — Contes africains illustrés et narrés (2–7 ans). App front-end 100% vanilla, hors-ligne, sans backend.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 5173",
    "serve": "npx --yes serve -l 5173 .",
    "test": "node --test \"tests/*.test.mjs\"",
    "test:e2e": "node tests/smoke.mjs",
    "codes": "node tools/generate-codes.js",
    "icons": "node tools/generate-icons.mjs",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap add android && npx cap sync android",
    "cap:ios": "npx cap add ios && npx cap sync ios",
    "tauri": "npx tauri dev"
  },
  "keywords": ["contes", "afrique", "pwa", "enfants", "offline", "vanilla", "capacitor"],
  "license": "UNLICENSED",
  "comment": "AUCUNE dépendance runtime. Les paquets ci-dessous ne servent qu'à l'empaquetage natif (Capacitor / Tauri) et ne sont PAS inclus dans le bundle web.",
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor-community/native-audio": "^6.0.0",
    "@capacitor-community/in-app-purchases": "^6.0.0",
    "@tauri-apps/cli": "^2.0.0",
    "playwright": "^1.44.0"
  }
}
