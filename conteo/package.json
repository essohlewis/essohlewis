{
  "name": "conteo",
  "version": "1.0.0",
  "private": true,
  "description": "CONTEO — Contes africains illustrés & narrés (2–7 ans). PWA vanilla + wrappers Capacitor/Tauri.",
  "scripts": {
    "serve": "php -S 127.0.0.1:8000 -t public public/router.php",
    "migrate": "php database/seeds/run.php migrate",
    "seed": "php database/seeds/run.php seed",
    "assets:demo": "php database/seeds/gen_demo_assets.php",
    "cap:sync": "cap sync",
    "cap:android": "cap add android && cap sync android",
    "cap:ios": "cap add ios && cap sync ios",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/screen-orientation": "^6.0.0",
    "@capacitor-community/native-audio": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@tauri-apps/cli": "^2.0.0"
  }
}
