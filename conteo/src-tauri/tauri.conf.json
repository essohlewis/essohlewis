{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Conteo",
  "version": "1.0.0",
  "identifier": "ci.conteo.app",
  "build": {
    "frontendDist": "../",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Conteo — Contes africains",
        "width": 1000,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' blob:; script-src 'self'; style-src 'self'; font-src 'self'; connect-src 'self' https://cdn.conteo.ci; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
