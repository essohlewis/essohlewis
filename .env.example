# ─────────────────────────────────────────────────────────────
# Transouscris — variables d'environnement (exemple)
# Copier vers .env et renseigner. NE JAMAIS committer le fichier .env réel.
# ─────────────────────────────────────────────────────────────

APP_NAME=Transouscris
APP_ENV=local            # local | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=                 # 32+ octets aléatoires en base64 (openssl rand -base64 32)
APP_TIMEZONE=Africa/Abidjan

# ── Base de données MySQL 8+ ──────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=transouscris
DB_USER=transouscris
DB_PASS=

# ── Sessions / sécurité ───────────────────────────────────────
SESSION_LIFETIME=7200
SESSION_SECURE=false     # true en production (HTTPS obligatoire)
CSRF_TOKEN_TTL=7200

# ── CinetPay (compte MARCHAND — paiements) ────────────────────
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=     # utilisée pour vérifier le HMAC du webhook
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_NOTIFY_URL=${APP_URL}/webhooks/cinetpay
CINETPAY_RETURN_URL=${APP_URL}/payment/return

# ── CinetPay SMS (compte SMS DISTINCT — OTP) ──────────────────
CINETPAY_SMS_API_KEY=
CINETPAY_SMS_SENDER=Transouscr
CINETPAY_SMS_BASE_URL=https://sms.cinetpay.com/api/v1

# ── PayDunya (Checkout + Disbursement) ────────────────────────
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test       # test | live
PAYDUNYA_BASE_URL=https://app.paydunya.com/api/v1

# ── Wave (optionnel) ──────────────────────────────────────────
WAVE_API_KEY=
WAVE_BASE_URL=https://api.wave.com/v1

# ── Stripe (support diaspora — carte internationale) ──────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Divers ────────────────────────────────────────────────────
OTP_TTL=300              # durée de validité d'un code OTP (secondes)
OTP_MAX_ATTEMPTS=5
RECHARGE_GUARANTEE_DELAY=900   # 15 min avant remboursement auto (secondes)
