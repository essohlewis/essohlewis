{
    "name": "transouscris/platform",
    "description": "Transouscris — plateforme de recharge de crédit et forfaits mobiles (Côte d'Ivoire) en PHP MVC pur.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Transouscris\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Transouscris\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "sort-packages": true
    }
}
